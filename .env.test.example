# ─────────────────────────────────────────────────────────────────────────────
# Test database configuration.
#
# Copy this file to `.env.test` (gitignored) and point it at a NON-production
# database. DB-backed tests (tests/*.db.test.ts) INSERT and DELETE rows — never
# put the production DATABASE_URL here. vitest.setup.ts refuses to run if the
# resolved DATABASE_URL matches a known production host.
#
# Option A — Neon branch (recommended): in the Neon console, create an instant
#   branch of your database and copy its connection string below. Branches are
#   isolated copies, so tests can freely mutate them.
#
# Option B — local Postgres:
#   TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hajihaz_test
#
# TEST_DATABASE_URL takes precedence over DATABASE_URL during tests.
# ─────────────────────────────────────────────────────────────────────────────

TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# After setting the URL, create the schema once:
#   node scripts/setup-test-db.mjs
# Then run the suite normally:
#   npm test
