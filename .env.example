# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database (Neon) — Step 2 ----
DATABASE_URL=

# ---- Auth.js — Step 3 ----
# Generate with: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Models / AI providers ----
DEFAULT_MODEL=ollama:qwen2.5
# Ollama (local dev default)
OLLAMA_BASE_URL=http://localhost:11434/api
# Gemini (production default) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# OpenRouter (fallback) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Groq (fast inference, chat only — no embeddings) — https://console.groq.com/keys
GROQ_API_KEY=
